---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Placeholder from './Placeholder.astro';

interface Props {
  src?: ImageMetadata;
  alt: string;
  pie?: string;
  ancho?: 'normal' | 'amplio' | 'completo';
  flota?: 'izquierda' | 'derecha' | 'no';
  etiquetaPlaceholder?: string;
}

const {
  src,
  alt,
  pie,
  ancho = 'normal',
  flota = 'no',
  etiquetaPlaceholder = 'IMAGEN',
} = Astro.props;
---

<figure class={`figura figura--${ancho} figura--flota-${flota}`}>
  {src ? (
    <Image src={src} alt={alt} loading="lazy" decoding="async" widths={[480, 768, 1200, 1800]} sizes="(max-width: 768px) 100vw, 70vw" />
  ) : (
    <Placeholder etiqueta={etiquetaPlaceholder} ratio="16/9" />
  )}
  {pie && <figcaption class="pie-figura">{pie}</figcaption>}
</figure>

<style>
  .figura {
    margin: var(--space-8) 0;
  }
  .figura img {
    width: 100%;
    height: auto;
    border-radius: var(--radio);
    box-shadow: var(--sombra-md);
  }

  .figura--amplio {
    margin-inline: calc((var(--ancho-prosa) - var(--ancho-prosa-ancho)) / 2);
    max-width: var(--ancho-prosa-ancho);
  }
  .figura--completo {
    width: 100vw;
    max-width: 100vw;
    margin-inline: calc(50% - 50vw);
    border-radius: 0;
  }
  .figura--completo img {
    border-radius: 0;
  }

  .figura--flota-izquierda,
  .figura--flota-derecha {
    max-width: 45%;
    margin-block: 0.5rem;
  }
  .figura--flota-izquierda { float: left;  margin-right: var(--space-6); }
  .figura--flota-derecha   { float: right; margin-left:  var(--space-6); }

  @media (max-width: 768px) {
    .figura--flota-izquierda,
    .figura--flota-derecha {
      float: none;
      max-width: 100%;
      margin-inline: 0;
    }
    .figura--amplio { margin-inline: 0; }
  }
</style>
