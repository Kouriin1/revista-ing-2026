---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Placeholder from './Placeholder.astro';

interface Item {
  src?: ImageMetadata;
  alt: string;
  pie?: string;
}
interface Props {
  items: Item[];
  columnas?: 2 | 3 | 4;
  titulo?: string;
}
const { items, columnas = 3, titulo } = Astro.props;
---

<section class="galeria" data-columnas={columnas}>
  {titulo && <h3 class="galeria__titulo">{titulo}</h3>}
  <div class="galeria__grid">
    {items.map((it, i) => (
      <figure class="galeria__item">
        {it.src ? (
          <Image src={it.src} alt={it.alt} loading="lazy" decoding="async" widths={[400, 800]} sizes="(max-width: 768px) 100vw, 33vw" />
        ) : (
          <Placeholder etiqueta={`GALERIA_IMAGEN_${String(i + 1).padStart(2, '0')}`} ratio="4/3" />
        )}
        {it.pie && <figcaption class="pie-figura">{it.pie}</figcaption>}
      </figure>
    ))}
  </div>
</section>

<style>
  .galeria { margin: var(--space-12) 0; }
  .galeria__titulo {
    font-size: var(--fs-md);
    margin-bottom: var(--space-6);
    text-align: center;
  }
  .galeria__grid {
    display: grid;
    gap: var(--space-4);
  }
  [data-columnas='2'] .galeria__grid { grid-template-columns: repeat(2, 1fr); }
  [data-columnas='3'] .galeria__grid { grid-template-columns: repeat(3, 1fr); }
  [data-columnas='4'] .galeria__grid { grid-template-columns: repeat(4, 1fr); }
  @media (max-width: 768px) {
    [data-columnas] .galeria__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    [data-columnas] .galeria__grid { grid-template-columns: 1fr; }
  }
  .galeria__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radio);
    transition: transform var(--t-media);
  }
  .galeria__item:hover img { transform: scale(1.02); }
</style>
