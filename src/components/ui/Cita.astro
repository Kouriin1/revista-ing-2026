---
interface Props {
  autor?: string;
  fuente?: string;
  variante?: 'estandar' | 'destacada' | 'pull';
}
const { autor, fuente, variante = 'estandar' } = Astro.props;
---

<aside class={`cita cita--${variante}`}>
  <blockquote>
    <slot />
  </blockquote>
  {(autor || fuente) && (
    <footer class="cita__atribucion">
      {autor && <cite class="cita__autor">— {autor}</cite>}
      {fuente && <span class="cita__fuente">{fuente}</span>}
    </footer>
  )}
</aside>

<style>
  .cita {
    margin: var(--space-10) 0;
  }
  .cita blockquote {
    margin: 0;
    padding: 0;
    font-family: var(--font-serif);
    font-style: italic;
    line-height: 1.5;
    color: var(--color-titulo);
  }

  .cita--estandar blockquote {
    border-left: 3px solid var(--color-acento);
    padding-left: var(--space-6);
    font-size: calc(var(--fs-md) * var(--fs-scale));
  }

  .cita--destacada {
    background: var(--color-fondo-alt);
    padding: var(--space-8);
    border-radius: var(--radio);
    border-top: 3px solid var(--color-acento);
    text-align: center;
  }
  .cita--destacada blockquote {
    font-size: calc(var(--fs-lg) * var(--fs-scale));
  }
  .cita--destacada blockquote::before { content: '«'; color: var(--color-acento); font-size: 2em; line-height: 0; vertical-align: -0.35em; margin-right: 0.15em; }
  .cita--destacada blockquote::after  { content: '»'; color: var(--color-acento); font-size: 2em; line-height: 0; vertical-align: -0.35em; margin-left: 0.15em; }

  .cita--pull {
    float: right;
    max-width: 320px;
    margin: var(--space-2) 0 var(--space-6) var(--space-8);
    padding: var(--space-4) 0;
    border-top: 2px solid var(--color-acento);
    border-bottom: 2px solid var(--color-acento);
    text-align: left;
  }
  .cita--pull blockquote {
    font-size: calc(var(--fs-lg) * var(--fs-scale));
    line-height: 1.3;
  }
  @media (max-width: 768px) {
    .cita--pull {
      float: none;
      max-width: 100%;
      margin: var(--space-8) 0;
    }
  }

  .cita__atribucion {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--font-sans);
  }
  .cita__autor {
    font-style: normal;
    font-weight: 700;
    color: var(--color-texto);
    font-size: var(--fs-sm);
  }
  .cita__fuente {
    color: var(--color-texto-tenue);
    font-size: var(--fs-xs);
  }
</style>
