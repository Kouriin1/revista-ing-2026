---
/**
 * Placeholder rediseñado — estético y estilo editorial
 * Muestra un patrón visual rico en lugar de un cuadro en blanco genérico
 */
interface Props {
  etiqueta: string;
  ratio?: string;
  alto?: string;
  variante?: 'claro' | 'oscuro' | 'dorado';
}
const { etiqueta, ratio = '16/9', alto, variante = 'oscuro' } = Astro.props;
const style = alto ? `height: ${alto};` : `aspect-ratio: ${ratio};`;
---

<div class={`placeholder placeholder--${variante}`} style={style} role="img" aria-label={etiqueta}>
  <svg class="placeholder__bg" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id={`grid-${etiqueta.replace(/\s/g,'')}`} width="60" height="60" patternUnits="userSpaceOnUse">
        <path d="M 60 0 L 0 0 0 60" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.15"/>
      </pattern>
      <pattern id={`dot-${etiqueta.replace(/\s/g,'')}`} width="20" height="20" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="1" fill="currentColor" opacity="0.12"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill={`url(#grid-${etiqueta.replace(/\s/g,'')})`}/>
    <rect width="100%" height="100%" fill={`url(#dot-${etiqueta.replace(/\s/g,'')})`}/>
  </svg>

  <div class="placeholder__inner">
    <!-- Ícono de cámara/imagen estilizado -->
    <div class="placeholder__icon-wrap">
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="placeholder__icon">
        <rect x="4" y="10" width="40" height="28" rx="4" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="24" cy="24" r="7" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="24" cy="24" r="3" fill="currentColor" opacity="0.4"/>
        <rect x="15" y="6" width="8" height="4" rx="2" fill="currentColor" opacity="0.5"/>
        <circle cx="38" cy="16" r="2" fill="currentColor" opacity="0.5"/>
      </svg>
    </div>
    <span class="placeholder__label">{etiqueta}</span>
  </div>
</div>

<style>
  .placeholder {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .placeholder--claro {
    background: linear-gradient(135deg, var(--color-papel-suave) 0%, var(--color-linea-suave) 100%);
    color: var(--color-azul-oxford-claro);
  }
  .placeholder--oscuro {
    background: linear-gradient(135deg, var(--color-azul-oxford-oscuro) 0%, var(--color-azul-oxford) 100%);
    color: rgba(255, 255, 255, 0.45);
  }
  .placeholder--dorado {
    background: linear-gradient(135deg, #3a2a00 0%, #5a4200 100%);
    color: var(--color-dorado);
  }
  .placeholder__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .placeholder__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-6);
    text-align: center;
  }
  .placeholder__icon-wrap {
    width: 64px;
    height: 64px;
    border: 1px solid currentColor;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.6;
  }
  .placeholder__icon {
    width: 32px;
    height: 32px;
  }
  .placeholder__label {
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.7;
    max-width: 24ch;
    line-height: 1.4;
  }
</style>
