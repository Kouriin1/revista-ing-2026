---
/**
 * Placeholder visual para imagenes pendientes de reemplazo.
 * Pinta un recuadro institucional con la etiqueta visible.
 */
interface Props {
  etiqueta: string;
  ratio?: string;           // ej "16/9", "4/3", "1/1"
  alto?: string;            // override en px o cualquier unidad
  variante?: 'claro' | 'oscuro' | 'dorado';
}
const { etiqueta, ratio = '16/9', alto, variante = 'claro' } = Astro.props;
const style = alto
  ? `height: ${alto};`
  : `aspect-ratio: ${ratio};`;
---

<div class={`placeholder placeholder--${variante}`} style={style} role="img" aria-label={etiqueta}>
  <svg class="placeholder__patron" aria-hidden="true">
    <defs>
      <pattern id={`p-${etiqueta}`} width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M0 40L40 0M-10 10L10 -10M30 50L50 30" stroke="currentColor" stroke-width="0.6" opacity="0.25" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill={`url(#p-${etiqueta})`} />
  </svg>
  <div class="placeholder__contenido">
    <span class="placeholder__icono" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <circle cx="9" cy="9" r="2"/>
        <path d="m21 15-5-5L5 21"/>
      </svg>
    </span>
    <span class="placeholder__etiqueta">{etiqueta}</span>
    <span class="placeholder__nota">Reemplazar en /content/ o /assets/</span>
  </div>
</div>

<style>
  .placeholder {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: var(--radio);
    border: 1px dashed currentColor;
  }
  .placeholder--claro {
    background: var(--color-fondo-alt);
    color: var(--color-azul-oxford-claro);
  }
  .placeholder--oscuro {
    background: var(--color-azul-oxford);
    color: var(--color-dorado-claro);
  }
  .placeholder--dorado {
    background: linear-gradient(135deg, var(--color-dorado-100), var(--color-dorado-200));
    color: var(--color-azul-oxford);
  }
  .placeholder__patron {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .placeholder__contenido {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    text-align: center;
    padding: var(--space-4);
  }
  .placeholder__etiqueta {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .placeholder__nota {
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    opacity: 0.7;
  }
</style>
