---
// Barra de progreso de lectura horizontal, fija arriba.
---

<div class="progreso-lectura" aria-hidden="true">
  <div class="progreso-lectura__barra" id="progreso-barra"></div>
</div>

<script>
  const init = () => {
    const barra = document.getElementById('progreso-barra');
    if (!barra) return;
    let raf = 0;
    const calcular = () => {
      const h = document.documentElement;
      const total = h.scrollHeight - h.clientHeight;
      const pct = total > 0 ? (window.scrollY / total) * 100 : 0;
      barra.style.transform = `scaleX(${Math.min(Math.max(pct / 100, 0), 1)})`;
    };
    const onScroll = () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(calcular);
    };
    calcular();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', calcular);
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>

<style>
  .progreso-lectura {
    position: fixed;
    top: 72px;
    left: 0;
    width: 100%;
    height: 3px;
    background: transparent;
    z-index: calc(var(--z-nav) - 1);
    pointer-events: none;
  }
  .progreso-lectura__barra {
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, var(--color-acento), var(--color-acento-fuerte));
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 60ms linear;
  }
  @media (max-width: 900px) {
    .progreso-lectura { top: 72px; }
  }
</style>
