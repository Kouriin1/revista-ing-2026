---
import BaseLayout from '@layouts/BaseLayout.astro';
import { obtenerEdicionActiva } from '@lib/edicion';
import { getCollection, getEntries, render } from 'astro:content';
import { Image } from 'astro:assets';
import portadaImg from '@assets/imagenes/portada_correcta.jpeg';
import usmLogo from '@assets/imagenes/usmlogo.png';
import PageFlipWrapper from '@components/islands/PageFlipWrapper.tsx';
import Placeholder from '@components/ui/Placeholder.astro';
import CabeceraArticulo from '@components/plantillas/CabeceraArticulo.astro';
import Referencias from '@components/ui/Referencias.astro';

const edicion = await obtenerEdicionActiva();
const fechaTexto = new Intl.DateTimeFormat('es', { month: 'long', year: 'numeric' }).format(edicion.data.fechaPublicacion);

// Buscamos todos los articulos que pertenezcan a la edicion actual
const articulos = await getCollection('articulos', ({ data }) => data.edicion === edicion.data.numero);
articulos.sort((a, b) => a.data.orden - b.data.orden);

// Preparamos como se va a dividir el indice si hay muchos articulos
const ITEMS_PRIMERA = 5;
const ITEMS_RESTO = 5;
const indiceChunks = [];
let currentIndex = 0;

while (currentIndex < articulos.length) {
  const isFirstPage = indiceChunks.length === 0;
  const itemsToTake = isFirstPage ? ITEMS_PRIMERA : ITEMS_RESTO;
  indiceChunks.push(articulos.slice(currentIndex, currentIndex + itemsToTake));
  currentIndex += itemsToTake;
}

const renders = await Promise.all(articulos.map(async (art) => {
  const { Content } = await render(art);
  const autoresResueltos = art.data.autores.length > 0 ? await getEntries(art.data.autores) : [];
  return { art, Content, autoresResueltos };
}));
---

<BaseLayout
  titulo={`${edicion.data.titulo} | Revista 3D`}
  descripcion={edicion.data.subtitulo}
  numeroEdicion={edicion.data.numero}
  ocultarHeader={true}
  ocultarFooter={true}
>
  <PageFlipWrapper client:only="react">
    
    <!-- 1. Pagina de Portada -->
    <div class="hoja-portada" style={`background-image: url('${portadaImg.src}')`}>
      {/* --- Elementos sobre la portada ocultos: ahora solo se muestra la imagen ---
      <div class="portada__logo-wrap">
        <Image src={usmLogo} alt="Universidad Santa María" class="portada__logo" />
      </div>
      <div class="portada__bottom">
        <h1 class="portada__titulo">{edicion.data.titulo}</h1>
        <p class="portada__sub">{edicion.data.subtitulo}</p>
        <span class="portada__edicion">Edición {edicion.data.numero} · {fechaTexto}</span>
      </div>
      --- fin elementos ocultos --- */}
    </div>

    <!-- 2. Paginas de Indice -->
    {indiceChunks.map((chunk, pageIndex) => {
      // Calculamos el numero inicial para la lista de esta pagina
      const startIndex = pageIndex === 0 ? 0 : ITEMS_PRIMERA + (pageIndex - 1) * ITEMS_RESTO;
      return (
        <div class="hoja-indice">
          <div class="indice-inner">
            {pageIndex === 0 && (
              <>
                <h2 class="indice-titulo">Índice</h2>
                <div class="indice-linea"></div>
              </>
            )}
            <ul class="indice-lista" style={pageIndex > 0 ? "margin-top: 0px;" : ""}>
              {chunk.map((a, i) => {
                const globalIndex = startIndex + i;
                return (
                  <li class="indice-item" data-articulo-idx={globalIndex}>
                    <span class="indice-num">{(globalIndex + 1).toString().padStart(2, '0')}</span>
                    <div class="indice-info">
                      <span class="indice-categoria">{a.data.seccion.toUpperCase()}</span>
                      <strong>{a.data.titulo}</strong>
                    </div>
                    <span class="indice-pag">—</span>
                  </li>
                );
              })}
            </ul>
          </div>
        </div>
      );
    })}

    <!-- 3. Paginas de los Articulos -->
    {renders.map(({ art, Content, autoresResueltos }, i) => (
      <div class="hoja-articulo" data-articulo-idx={i}>
        {/* Franja decorativa de arriba con el numero y la categoria */}
        <div class="art-franja">
          <span class="art-franja__num">{String(i + 1).padStart(2, '0')}</span>
          <div class="art-franja__linea"></div>
          <span class="art-franja__seccion">{art.data.seccion.toUpperCase()}</span>
        </div>

        <CabeceraArticulo articulo={art} autoresResueltos={autoresResueltos} variante="centrada" />
        
        <div class="plantilla-a__cuerpo prosa dropcap">
          <Content />
        </div>

        {art.data.referencias && art.data.referencias.length > 0 && (
          <section class="referencias-seccion">
            <div class="refs-encabezado">
              <span class="refs-linea"></span>
              <span class="refs-titulo">Referencias</span>
              <span class="refs-linea"></span>
            </div>
            <Referencias items={art.data.referencias} />
          </section>
        )}
      </div>
    ))}

    <!-- 4. Pagina final de Contraportada -->
    <div class="hoja-contraportada">
      <div class="contraportada-content">
        <Image src={usmLogo} alt="Logo USM" class="contraportada__logo" />
      </div>
    </div>

  </PageFlipWrapper>
</BaseLayout>

<style>
  /* Estilos de la portada */
  .hoja-portada {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  /* Logo en la parte superior — pegado al tope */
  .portada__logo-wrap {
    position: absolute;
    top: 12px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    z-index: 3;
  }
  .portada__logo {
    width: 140px;
    height: auto;
    /* Sin fondo, sin borde — logo limpio */
    background: none !important;
    padding: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    /* Sombra de texto suave para que se vea sobre cualquier fondo */
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.6));
  }
  /* Franja inferior con título */
  .portada__bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    background: linear-gradient(transparent, rgba(0, 10, 40, 0.95) 25%);
    padding: 60px 28px 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .portada__titulo {
    font-family: 'Georgia', var(--font-serif), serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: #FFFFFF !important;
    text-shadow: 0 2px 6px rgba(0,0,0,0.8);
    line-height: 1.3;
    margin: 0;
    text-wrap: balance;
    letter-spacing: 0.01em;
  }
  .portada__sub {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: #FFFFFF !important;
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
    margin: 0;
    font-style: italic;
    letter-spacing: 0.03em;
  }
  .portada__edicion {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #FFFFFF !important;
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
    margin-top: 4px;
  }

  /* Índice */
  .hoja-indice {
    padding: 0 5px; /* Reducido drásticamente para dar más ancho al texto */
    background: transparent; /* El fondo ya lo da la hoja base */
  }
  .indice-inner {
    max-width: 100%;
  }
  .indice-titulo {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: #002147;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .indice-linea {
    height: 2px;
    background: #C5A059;
    margin: 4px 0 6px;
    width: 100%;
  }
  .indice-lista {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .indice-item {
    display: flex;
    gap: 6px;
    align-items: flex-start;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    padding-bottom: 4px;
  }
  .indice-num {
    font-family: var(--font-serif);
    font-size: 0.75rem;
    font-weight: 700;
    color: #C5A059;
    line-height: 1;
    min-width: 20px;
  }
  .indice-info {
    display: flex;
    flex-direction: column;
    gap: 0px;
    flex: 1; /* Permite que tome todo el espacio disponible empujando el número de pág */
    min-width: 0; /* CRUCIAL: Permite que el flex item se encoja y el texto haga wrap */
    padding-right: 12px;
  }
  .indice-categoria {
    font-family: var(--font-sans);
    font-size: 0.4rem;
    letter-spacing: 0.08em;
    color: #C5A059;
    font-weight: 700;
    text-transform: uppercase;
  }
  .indice-info strong {
    font-family: var(--font-serif);
    font-size: 0.58rem;
    color: #002147 !important;
    line-height: 1.2;
    font-weight: 700;
    background: transparent !important; /* Quitar fondo amarillo heredado */
    padding: 0 !important;
    text-align: left;
  }
  .indice-info p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: #4A4A4A;
    line-height: 1.4;
  }
  .indice-pag {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 800;
    color: #002147;
    white-space: nowrap; /* Evita que el "p. 69" se parta en dos líneas */
    min-width: 35px;
    text-align: right;
  }

  /* Artículos (Prosa ajustada) */
  .hoja-articulo {
    padding: 10px 0 16px;
  }

  /* ── Franja decorativa de artículo (igual al índice) ── */
  .art-franja {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }
  .art-franja__num {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    font-weight: 700;
    color: #C5A059;
    line-height: 1;
    min-width: 20px;
  }
  .art-franja__linea {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, #C5A059, rgba(197, 160, 89, 0.12));
  }
  .art-franja__seccion {
    font-family: var(--font-sans);
    font-size: 0.45rem;
    letter-spacing: 0.12em;
    color: #C5A059;
    font-weight: 700;
    text-transform: uppercase;
  }

  /* ── Encabezado de referencias ── */
  .refs-encabezado {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 5px;
    margin-top: 8px;
  }
  .refs-linea {
    flex: 1;
    height: 1px;
    background: rgba(0, 33, 71, 0.12);
  }
  .refs-titulo {
    font-family: var(--font-sans);
    font-size: 0.5rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #8A8A8A;
    white-space: nowrap;
  }
  
  /* Contraportada */
  .hoja-contraportada {
    width: 100%;
    height: 100%;
    min-height: 800px;
    background: var(--color-azul-oxford-oscuro);
    color: #FFFFFF !important;
    text-shadow: 0 1px 3px rgba(0,0,0,0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  .contraportada-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }
  .contraportada__logo {
    width: 140px;
    height: auto;
    margin-bottom: 40px;
    background: none !important;
    padding: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
  }
</style>
