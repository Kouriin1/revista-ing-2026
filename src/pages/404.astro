---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout titulo="Página no encontrada" descripcion="404 — Página no encontrada">
  <section class="not-found contenedor">
    <div class="not-found__inner">
      <span class="not-found__codigo">404</span>
      <h1>Página no encontrada</h1>
      <p>El contenido que buscas no existe o ha sido movido.</p>
      <a href="/" class="not-found__cta">← Volver a la portada</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70dvh;
    padding-block: var(--space-16);
  }
  .not-found__inner {
    text-align: center;
    max-width: 480px;
  }
  .not-found__codigo {
    font-family: var(--font-serif);
    font-size: clamp(6rem, 18vw, 12rem);
    color: var(--color-acento);
    line-height: 0.9;
    display: block;
  }
  .not-found h1 {
    font-size: var(--fs-xl);
    margin: var(--space-4) 0;
  }
  .not-found p {
    color: var(--color-texto-suave);
    margin-bottom: var(--space-6);
  }
  .not-found__cta {
    display: inline-block;
    padding: 12px 24px;
    background: var(--color-azul-oxford);
    color: var(--color-papel);
    text-decoration: none;
    border-radius: var(--radio-sm);
    font-family: var(--font-sans);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--fs-sm);
  }
  .not-found__cta:hover {
    background: var(--color-azul-oxford-oscuro);
  }
</style>
