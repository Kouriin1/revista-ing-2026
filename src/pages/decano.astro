---
import BaseLayout from '@layouts/BaseLayout.astro';
import Placeholder from '@components/ui/Placeholder.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import { obtenerEdicionActiva } from '@lib/edicion';

const edicion = await obtenerEdicionActiva();
const docs = await getCollection('institucional', ({ data }) => data.tipo === 'mensaje-decano');
const mensaje = docs[0];
const Contenido = mensaje ? (await render(mensaje)).Content : null;
---

<BaseLayout
  titulo="Mensaje del Decano | Facultad de Ingeniería"
  descripcion="Mensaje institucional"
  numeroEdicion={edicion.data.numero}
>
  <article class="pagina-decano">
    <div class="contenedor contenedor--lectura">
      <header class="decano-header revelar">
        <span class="overline">Mensaje institucional</span>
        <h1>{mensaje?.data.titulo ?? '[TITULO_MENSAJE_DECANO]'}</h1>
      </header>

      <div class="decano-perfil revelar">
        <div class="decano-perfil__foto">
          {mensaje?.data.foto ? (
            <Image src={mensaje.data.foto} alt={mensaje.data.autor ?? 'Decano'} widths={[280, 560]} sizes="240px" />
          ) : (
            <Placeholder etiqueta="FOTO_DECANO" ratio="1/1" variante="dorado" />
          )}
        </div>
        <div class="decano-perfil__info">
          <h2 class="decano-perfil__nombre">{mensaje?.data.autor ?? '[NOMBRE_DECANO]'}</h2>
          <p class="decano-perfil__cargo">{mensaje?.data.cargo ?? '[CARGO_DECANO]'}</p>
          <p class="decano-perfil__institucion">Facultad de Ingeniería</p>
        </div>
      </div>

      <div class="decano-cuerpo prosa dropcap revelar">
        {Contenido ? (
          <Contenido />
        ) : (
          <>
            <p>
              [Crea un archivo <code>src/content/institucional/decano.md</code> con
              <code>tipo: mensaje-decano</code> para reemplazar este contenido. El cuerpo del
              mensaje se renderizará aquí con la tipografía académica completa.]
            </p>
            <p>
              [PARRAFO_PLACEHOLDER_1] Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed
              do eiusmod tempor incididunt ut labore et dolore magna aliqua.
            </p>
            <p>
              [PARRAFO_PLACEHOLDER_2] Ut enim ad minim veniam, quis nostrud exercitation ullamco
              laboris nisi ut aliquip ex ea commodo consequat.
            </p>
          </>
        )}
      </div>

      <footer class="decano-firma revelar">
        <div class="firma-linea"></div>
        <p class="firma-nombre">{mensaje?.data.autor ?? '[NOMBRE_DECANO]'}</p>
        <p class="firma-cargo">{mensaje?.data.cargo ?? '[CARGO_DECANO]'}</p>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .pagina-decano {
    padding-block: var(--space-16) var(--space-20);
  }
  .decano-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }
  .decano-header h1 {
    font-size: var(--fs-3xl);
    margin-top: var(--space-3);
    max-width: 22ch;
    margin-inline: auto;
  }
  .decano-perfil {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--space-8);
    align-items: center;
    padding: var(--space-6) 0 var(--space-10);
    margin-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-linea-base);
  }
  .decano-perfil__foto {
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: var(--sombra-lg);
    border: 4px solid var(--color-papel);
    outline: 2px solid var(--color-acento);
  }
  .decano-perfil__foto :global(img),
  .decano-perfil__foto :global(.placeholder) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .decano-perfil__nombre {
    font-size: var(--fs-xl);
    margin: 0;
  }
  .decano-perfil__cargo {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-acento-fuerte);
    margin: var(--space-1) 0;
  }
  .decano-perfil__institucion {
    color: var(--color-texto-suave);
    font-size: var(--fs-sm);
    margin: 0;
  }

  .decano-cuerpo {
    margin: 0 auto;
  }

  .decano-firma {
    text-align: center;
    margin-top: var(--space-16);
    padding-top: var(--space-8);
  }
  .firma-linea {
    width: 120px;
    height: 1px;
    background: var(--color-texto-suave);
    margin: 0 auto var(--space-3);
  }
  .firma-nombre {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--fs-md);
    color: var(--color-titulo);
    margin: 0;
  }
  .firma-cargo {
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-texto-tenue);
    margin: var(--space-1) 0 0;
  }

  @media (max-width: 768px) {
    .decano-perfil {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .decano-perfil__foto {
      max-width: 200px;
      margin: 0 auto;
    }
  }
</style>
